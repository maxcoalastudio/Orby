FROM php:8.5-apache

# Instala extensões necessárias (SQLite, PDO)
RUN docker-php-ext-install pdo_sqlite

# Habilita mod_rewrite para URLs amigáveis
RUN a2enmod rewrite

# Configura o DocumentRoot para apontar para a pasta public
RUN sed -i 's|DocumentRoot /var/www/html|DocumentRoot /var/www/html/public|' /etc/apache2/sites-available/000-default.conf

# Permite o uso do .htaccess (para suas rotas amigáveis)
RUN sed -i '/<Directory \/var\/www\/html>/,/<\/Directory>/ s/AllowOverride None/AllowOverride All/' /etc/apache2/apache2.conf

# Define a porta que o Render espera
ENV PORT=10000
RUN sed -i "s/80/${PORT}/g" /etc/apache2/ports.conf
RUN sed -i "s/:80/:${PORT}/g" /etc/apache2/sites-available/000-default.conf

# Copia todo o projeto para dentro do container
COPY . /var/www/html/

EXPOSE 10000
CMD ["apache2-foreground"]